@page
@using LeisnerCare.Core.Entities
@model LeisnerCare.Web.Pages.Reports.PatientReportModel
@{
    ViewData["Title"] = "Patient Rapport";
}

@if (!Model.SelectedPatientId.HasValue)
{
    <h1>Generer Patient Rapport</h1>
    <form method="get">
        <div class="form-group mb-3">
            <label>Vælg patient</label>
            <select asp-for="SelectedPatientId" asp-items="Model.Patients" class="form-control form-control-lg">
                <option value="">-- Vælg --</option>
            </select>
        </div>
        <button type="submit" class="btn btn-primary btn-lg">Vis rapport</button>
    </form>
}
else if (Model.Patient != null)
{
    <div class="d-print-none mb-3">
        <a asp-page="./PatientReport" class="btn btn-secondary btn-lg">← Tilbage</a>
        <button onclick="window.print()" class="btn btn-success btn-lg">🖨️ Gem som PDF</button>
    </div>

    <div class="report-container p-4 border">
        <div class="text-center mb-4">
            <h1>LeisnerCare - Patient Rapport</h1>
            <p class="text-muted">Genereret: @Model.ReportDate.ToString("dd. MMMM yyyy")</p>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h3>Patientoplysninger</h3>
            </div>
            <div class="card-body">
                <p><strong>Navn:</strong> @Model.Patient.User?.FirstName @Model.Patient.User?.LastName</p>
                <p><strong>CPR:</strong> @Model.Patient.CprNumber</p>
                <p><strong>Fødselsdato:</strong> @Model.Patient.DateOfBirth.ToShortDateString()</p>
                <p><strong>Diagnose:</strong> @Model.Patient.DiagnosisDate.ToShortDateString()</p>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <h3>Symptomer (sidste 30 dage)</h3>
            </div>
            <div class="card-body">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Dato</th>
                            <th>Type</th>
                            <th>Værdi</th>
                            <th>Note</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.Symptoms)
                        {
                            <tr>
                                <td>@s.RecordedAt.ToString("dd/MM yyyy HH:mm")</td>
                                <td>@s.Type</td>
                                <td>
                                    @if (s.Type == SymptomType.OnOff)
                                    {
                                        @(s.Value == 0 ? "ON" : s.Value == 1 ? "OFF" : "DYSKINESI")
                                    }
                                    else
                                    {
                                        @s.Value
                                    }
                                </td>
                                <td>@s.Note</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-success text-white">
                <h3>Medicin</h3>
            </div>
            <div class="card-body">
                @foreach (var med in Model.Medications)
                {
                    <h5>@med.Name - @med.Dosage (@med.Frequency)</h5>
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Taget</th>
                                <th>Effekt</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in med.Logs.OrderByDescending(l => l.TakenAt).Take(10))
                            {
                                <tr>
                                    <td>@log.TakenAt.ToString("dd/MM HH:mm")</td>
                                    <td>@(log.Effectiveness?.ToString() ?? "-")/5</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <div class="text-center text-muted mt-4">
            <p>LeisnerCare Parkinson Monitor - Rapport genereret af sundhedspersonale</p>
        </div>
    </div>
}

<style media="print">
    .d-print-none {
        display: none !important;
    }

    .report-container {
        border: none !important;
    }

    body {
        font-size: 12pt;
    }

    .card {
        break-inside: avoid;
    }
</style>