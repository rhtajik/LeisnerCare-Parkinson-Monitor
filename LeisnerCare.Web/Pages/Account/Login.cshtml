@page
@model LeisnerCare.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Log ind";
}

<h1>Log ind</h1>

<form method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="form-group mb-3">
        <label asp-for="Input.Email">Email</label>
        <input asp-for="Input.Email" class="form-control" type="email" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Input.Password">Password</label>
        <input asp-for="Input.Password" class="form-control" type="password" />
    </div>

    <div class="form-group mb-3">
        <input asp-for="Input.RememberMe" type="checkbox" />
        <label asp-for="Input.RememberMe">Husk mig</label>
    </div>

    <button type="submit" class="btn btn-primary btn-lg">Log ind</button>
</form>

<p class="mt-3">
    <a asp-page="./Register">Opret ny konto</a>
</p>