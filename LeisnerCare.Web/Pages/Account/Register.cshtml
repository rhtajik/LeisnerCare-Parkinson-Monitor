@page
@model LeisnerCare.Web.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Registrer";
}

<h1>Opret konto</h1>

<form method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="form-group mb-3">
        <label asp-for="Input.FirstName">Fornavn</label>
        <input asp-for="Input.FirstName" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Input.LastName">Efternavn</label>
        <input asp-for="Input.LastName" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Input.Email">Email</label>
        <input asp-for="Input.Email" class="form-control" type="email" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Input.Password">Password</label>
        <input asp-for="Input.Password" class="form-control" type="password" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Input.ConfirmPassword">Bekræft password</label>
        <input asp-for="Input.ConfirmPassword" class="form-control" type="password" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Input.Role">Rolle</label>
        <select asp-for="Input.Role" class="form-control" asp-items="Html.GetEnumSelectList<LeisnerCare.Core.Entities.UserRole>()">
        </select>
    </div>

    <button type="submit" class="btn btn-primary btn-lg">Opret konto</button>
</form>