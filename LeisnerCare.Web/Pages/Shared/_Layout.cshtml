<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LeisnerCare</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LeisnerCare.Web.styles.css" asp-append-version="true" />
    <style>
        /* Parkinson-venligt UI - store klikbare områder */
        .navbar-brand { font-size: 1.5rem; font-weight: bold; }
        .nav-link { font-size: 1.1rem; padding: 0.75rem 1rem !important; }
        .btn-nav { font-size: 1.1rem; padding: 0.5rem 1.5rem; }
        .navbar { padding-top: 0.75rem; padding-bottom: 0.75rem; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-primary border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">🧠 LeisnerCare</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-page="/Index">Forside</a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Staff"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-page="/Patients/Index">Patienter</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-page="/Staff/SymptomOverview">Symptomer</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-page="/Medications/Create">Registrer Medicin</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-page="/Staff/MedicationOverview">Medicin</a>
                                </li>
                            }

                            @if (User.IsInRole("Patient"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-page="/Symptoms/Create">Registrer Symptom</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-page="/Symptoms/History">Min Historik</a>
                                </li>
                            }
                            @if (User.IsInRole("Patient") || User.IsInRole("Relative"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-page="/Medications/Today">Dagens Medicin</a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-white">👤 @User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form method="post" asp-page="/Account/Logout" class="form-inline">
                                    <button type="submit" class="btn btn-outline-light btn-nav">Log ud</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-nav me-2" asp-page="/Account/Login">Log ind</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-light btn-nav" asp-page="/Account/Register">Opret konto</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center">
            &copy; 2026 - LeisnerCare Parkinson Monitor
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>